# ─────────────────────────────────────────────────────────────────────────────
# Banco de dados (Drizzle / MySQL)
# Aceita formato: mysql://user:pass@host:port/db
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=mysql://root:CHANGEME@localhost:3306/portfolio

# ─────────────────────────────────────────────────────────────────────────────
# Auth — segredo de assinatura dos JWT de sessão (mínimo 32 chars aleatórios)
# Gere com: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGEME_minimum_32_chars_random_string

# ─────────────────────────────────────────────────────────────────────────────
# Admin allowlist por IP (CSV) — vazio = só localhost
# Ex: ADMIN_ALLOWED_IPS=1.2.3.4,5.6.7.8
# ─────────────────────────────────────────────────────────────────────────────
ADMIN_ALLOWED_IPS=

# ─────────────────────────────────────────────────────────────────────────────
# OWNER_OPEN_ID — openId que recebe role=admin automaticamente após OAuth
# ─────────────────────────────────────────────────────────────────────────────
OWNER_OPEN_ID=

# ─────────────────────────────────────────────────────────────────────────────
# GitHub — usado SOMENTE se você ressuscitar a página /github (hoje redireciona
# pro perfil externo). Token opcional pra aumentar o rate-limit do API público.
# ─────────────────────────────────────────────────────────────────────────────
GITHUB_USERNAME=vitordsb
GITHUB_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# OAuth (Manus / portal externo)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_OAUTH_PORTAL_URL=
NEXT_PUBLIC_APP_ID=
